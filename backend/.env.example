# Tyrion — variables de entorno
# Copiar a .env y completar los valores reales.

# Base de datos (en Docker usa el alias del servicio "db")
DATABASE_URL=postgresql://tyrion:tyrion@db:5432/tyrion

# Pantalla Control: true = usar los 8 trámites de prueba (sin BD real)
USE_DATOS_PRUEBA=true

# Claude API (opcional: si está vacía, usa clasificador mock — perfecto para demo sin cuenta Anthropic)
ANTHROPIC_API_KEY=

# Ingesta de email — IMAP (Gmail: activar "acceso de apps menos seguras" o usar app password)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX

# Envío de avisos — SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_REMITENTE=

# Email del administrativo (escalado como último recurso)
EMAIL_ADMINISTRATIVO=

# Timers de escalado (minutos)
ESCALADO_AVISO2_MIN=30
ESCALADO_ADMIN_MIN=60

# Directorios de almacenamiento
WATCH_DIR=/tmp/tyrion_watch
UPLOADS_DIR=/tmp/tyrion_uploads
